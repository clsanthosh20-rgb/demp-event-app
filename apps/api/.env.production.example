# Firebase - these are auto-set in Cloud Functions environment
# FIREBASE_SERVICE_ACCOUNT is set automatically by the Cloud Functions runtime
# FIREBASE_STORAGE_BUCKET is set automatically

# JWT Configuration
JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# SMTP (optional - for email notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@demp.local"

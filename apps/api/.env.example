# SQLite for development, PostgreSQL for production
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# SMTP (optional - for email notifications)
# Set these to enable email sending. Without SMTP, emails are logged to console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@demp.local"

# For Render:
# - Add these same variables in your Render dashboard under Environment
# - Use a real SMTP service (e.g. SendGrid, Mailgun, Gmail SMTP)
# - SMTP_SECURE="true" for port 465, "false" for port 587 (STARTTLS)
